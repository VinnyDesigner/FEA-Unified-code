  "faq": {
    "pageTitle": "الأسئلة المتداولة",
    "pageSubtitle": "كل ما تحتاج إلى معرفته — تمت الإجابة عليه بوضوح وإيجاز.",
    "q1": "ما هو تطبيق جودة المياه البحرية؟",
    "a1": "يوفر هذا التطبيق بيانات في الوقت الفعلي وتاريخية حول جودة المياه البحرية في جميع أنحاء الفجيرة لدعم المراقبة البيئية وصنع القرار.",
    "q2": "من يدير هذا التطبيق؟",
    "a2": "تتم إدارة التطبيق من قبل هيئة البيئة بالفجيرة (FEA) لضمان الإدارة الساحلية المستدامة.",
    "q3": "ما نوع البيانات المتاحة في التطبيق؟",
    "a3": "يوفر التطبيق مقاييس مثل التوصيل النوعي، ودرجة حرارة الماء، والملوحة، والكلوروفيل، والأكسجين المذاب، والتعكر، والرقم الهيدروجيني، ومستويات الطحالب الخضراء المزرقة.",
    "q4": "كم مرة يتم تحديث البيانات؟",
    "a4": "يتم تحديث البيانات عادةً في الوقت الفعلي تقريبًا، اعتمادًا على تردد الإرسال لعوامات المراقبة المتمركزة على طول الساحل.",
    "q5": "ما مدى دقة البيانات؟",
    "a5": "يتم جمع البيانات باستخدام أجهزة استشعار بيئية عالية الدقة (مسابير) تتم معايرتها وصيانتها بانتظام لتحقيق أقصى قدر من الدقة.",
    "q6": "ماذا تعني مؤشرات جودة المياه؟",
    "a6": "يمثل كل مؤشر خاصية كيميائية أو فيزيائية معينة للمياه تساعد علماء البيئة على تقييم الصحة العامة للنظام البيئي البحري.",
    "q7": "كيف يمكنني عرض بيانات جودة المياه لموقع معين؟",
    "a7": "يمكنك استخدام عرض الخريطة التفاعلية في لوحة القيادة للنقر على علامات محددة للمحطة أو استخدام القائمة المنسدلة للمحطة في أقسام التحليلات.",
    "q8": "هل يمكنني تنزيل البيانات أو تصديرها؟",
    "a8": "نعم، يمكنك إنشاء وتنزيل تقارير بيئية مفصلة من خلال قسم التقارير المخصص في التطبيق.",
    "q9": "ماذا تمثل مؤشرات الألوان على الخريطة؟",
    "a9": "تمثل الألوان عادةً الحالة الحالية لمعايير جودة المياه بالنسبة لمعايير السلامة والبيئة المعمول بها (مثل الأخضر للحالة الجيدة، والأحمر للحالة الحرجة)."
  },
