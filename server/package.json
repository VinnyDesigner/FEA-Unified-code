{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:contract": "node --test tests/contract/fe-shapes.test.js",
    "prisma:generate": "prisma generate --schema=prisma/mwq/schema && prisma generate --schema=prisma/aqms/schema",
    "prisma:migrate:dev": "prisma migrate dev --schema=prisma/mwq/schema && prisma migrate dev --schema=prisma/aqms/schema",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/mwq/schema && prisma migrate deploy --schema=prisma/aqms/schema",
    "prisma:studio:mwq": "prisma studio --schema=prisma/mwq/schema",
    "prisma:studio:aqms": "prisma studio --schema=prisma/aqms/schema",
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "docx": "^9.7.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.18.0",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
