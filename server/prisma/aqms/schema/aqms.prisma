  cemsObs             AqmsCEMSAirQualityObservation[]
  ambientHourly       AqmsAmbientAirQualityHourlyStats[]
  ambientDaily        AqmsAmbientAirQualityDailyStats[]
  ambientMonthly      AqmsAmbientAirQualityMonthlyStats[]
  metHourly           AqmsMeteorologicalHourlyStats[]
