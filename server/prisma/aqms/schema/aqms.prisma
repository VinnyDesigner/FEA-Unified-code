// ─── 1. MonitoringSite ───────────────────────────────────────────────────────
model AqmsMonitoringSite {
  id               Int     @id @default(autoincrement()) @map("StationID")
  stationCode      String  @unique @map("StationCode") @db.VarChar(40)
  stationName      String  @map("StationName") @db.VarChar(120)
  description      String  @map("Description") @db.Text
  stationType      String  @map("StationType") @db.VarChar(40)
  latitude         Decimal @map("Latitude") @db.Decimal(9, 6)
  longitude        Decimal @map("Longitude") @db.Decimal(9, 6)
  street           String? @map("Street") @db.VarChar(255)
  city             String? @map("City") @db.VarChar(80)
  state            String? @map("State") @db.VarChar(80)
  zipCode          String? @map("ZipCode") @db.VarChar(20)
  areaType         String  @map("AreaType") @db.VarChar(40)
  operationalState String  @map("OperationalState") @db.VarChar(40)
  status           String  @map("Status") @db.VarChar(20)

  sensorDetails   AqmsSensorDetails[]
  siteParameters  AqmsSiteParameter[]
  ambientObs      AqmsAmbientAirQualityObservation[]
  metObs          AqmsMeteorologicalObservation[]
  cemsObs         AqmsCEMSAirQualityObservation[]
  aqiHourly       AqmsAirQualityIndexHourlyStats[]
  aqiDaily        AqmsAirQualityIndexDailyStats[]
  aqiMonthly      AqmsAirQualityIndexMonthlyStats[]
  aqiYearly       AqmsAirQualityIndexYearlyStats[]
  ambientHourly   AqmsAmbientAirQualityHourlyStats[]
  ambientDaily    AqmsAmbientAirQualityDailyStats[]
  ambientMonthly  AqmsAmbientAirQualityMonthlyStats[]
  metHourly       AqmsMeteorologicalHourlyStats[]
  metDaily        AqmsMeteorologicalDailyStats[]
  metMonthly      AqmsMeteorologicalMonthlyStats[]
  cemsHourly      AqmsCEMSAirQualityHourlyStats[]
  cemsDaily       AqmsCEMSAirQualityDailyStats[]
  cemsMonthly     AqmsCEMSAirQualityMonthlyStats[]
  dataCompHourly  AqmsDataCompletenessHourlyStats[]
  dataCompDaily   AqmsDataCompletenessDailyStats[]
  dataCompMonthly AqmsDataCompletenessMonthlyStats[]
  violationLogs   AqmsDataViolationLog[]
  windRoseLogs    AqmsWindRoseLog[]

  @@map("aqms_monitoring_sites")
}

// ─── 2. SensorDetails (AQMS asset registry) ──────────────────────────────────
model AqmsSensorDetails {
  id                  Int       @id @default(autoincrement()) @map("AssetID")
  stationId           Int       @map("StationID")
  serialNumber        String    @map("SerialNumber") @db.VarChar(60)
  manufacturer        String    @map("Manufacturer") @db.VarChar(120)
  modelNumber         String    @map("ModelNumber") @db.VarChar(120)
  installationDate    DateTime  @map("InstallationDate") @db.Date
  purchaseDate        DateTime  @map("PurchaseDate") @db.Date
  retiredDate         DateTime? @map("RetiredDate") @db.Date
  assetTag            String    @map("AssetTag") @db.VarChar(60)
  certifyingAuthority String?   @map("CertifyingAuthority") @db.VarChar(120)
  certificationDate   DateTime? @map("CertificationDate") @db.Date
  owner               String    @map("Owner") @db.VarChar(120)

  station AqmsMonitoringSite @relation(fields: [stationId], references: [id])

  @@index([stationId])
  @@map("aqms_sensor_details")
}

// ─── 3. SamplingFrequency ────────────────────────────────────────────────────
model AqmsSamplingFrequency {
  id            Int    @id @default(autoincrement()) @map("SamplingFrequencyID")
  frequencyName String @map("FrequencyName") @db.VarChar(60)
  timeInterval  String @map("TimeInterval") @db.VarChar(20)
  intervalValue Int    @map("IntervalValue")

  siteParameters AqmsSiteParameter[]

  @@map("aqms_sampling_frequencies")
}

