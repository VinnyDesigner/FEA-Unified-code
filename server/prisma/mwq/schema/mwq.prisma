  observationTime  DateTime @map("ObservationTime") @db.Timestamptz(6)
  directionSector  String   @map("DirectionSector") @db.VarChar(8)
  windSpeedClass   String   @map("WindSpeedClass") @db.VarChar(40)
  frequencyPercent Decimal  @map("FrequencyPercent") @db.Decimal(5, 2)
  remarks          String?  @map("Remarks")

  buoy MwqBuoy @relation(fields: [buoyId], references: [id])

  @@map("mwq_wind_rose_summaries")
}

// Entity 22: LoggerSystemInfo
model MwqLoggerSystemInfo {
  id               Int      @id @default(autoincrement()) @map("LoggerID")
  buoyId           Int      @map("BuoyID")
  serialNumber     String   @map("SerialNumber") @db.VarChar(60)
  revBoard         String   @map("RevBoard") @db.VarChar(40)
  osVersion        String   @map("OSVersion") @db.VarChar(40)
  osDate           DateTime @map("OSDate") @db.Date
  osSignature      String   @map("OSSignature") @db.VarChar(64)
  programName      String   @map("ProgramName") @db.VarChar(120)
  programSignature String   @map("ProgramSignature") @db.VarChar(64)
  runSignature     String   @map("RunSignature") @db.VarChar(64)
  startTime        DateTime @map("StartTime") @db.Timestamptz(6)
  compileResults   String   @map("CompileResults")

  buoy             MwqBuoy                    @relation(fields: [buoyId], references: [id])
  runtimeStatuses  MwqLoggerRuntimeStatus[]
  calibrationInfos MwqLoggerCalibrationInfo[]
  healthMetaData   MwqStationHealthMetaData[]

  @@map("mwq_logger_system_infos")
}

// Entity 23: LoggerRuntimeStatus [BigInt PK]
model MwqLoggerRuntimeStatus {
  id                 BigInt   @id @default(autoincrement()) @map("StatusID")
  loggerId           Int      @map("LoggerID")
  timestamp          DateTime @map("Timestamp") @db.Timestamptz(6)
  watchdogErrors     Int      @map("WatchdogErrors")
  progErrors         Int      @map("ProgErrors")
  varOutOfBound      Int      @map("VarOutOfBound")
  skippedScan        Int      @map("SkippedScan")
  programName        String   @map("ProgramName") @db.VarChar(120)
  skippedSlowScan    Int      @map("SkippedSlowScan")
  serialFlashErrors  Int      @map("SerialFlashErrors")
  wifiUpdateRequired Boolean  @map("WiFiUpdateRequired")
  sw12Volts          Decimal  @map("SW12Volts") @db.Decimal(5, 2)
  commsMemFree       Int      @map("CommsMemFree")

  logger       MwqLoggerSystemInfo   @relation(fields: [loggerId], references: [id])
  portStatuses MwqLoggerPortStatus[]

  @@index([loggerId, timestamp(sort: Desc)])
  @@map("mwq_logger_runtime_statuses")
}

// Entity 24: LoggerPortStatus [BigInt PK]
model MwqLoggerPortStatus {
  id         BigInt @id @default(autoincrement()) @map("PortStatusID")
  statusId   BigInt @map("StatusID")
  portNumber Int    @map("PortNumber")
  portStatus String @map("PortStatus") @db.VarChar(20)
  portConfig String @map("PortConfig")

  runtimeStatus MwqLoggerRuntimeStatus @relation(fields: [statusId], references: [id])

  @@map("mwq_logger_port_statuses")
}

// Entity 25: LoggerCalibrationInfo
model MwqLoggerCalibrationInfo {
  id              Int     @id @default(autoincrement()) @map("CalibrationID")
  loggerId        Int     @map("LoggerID")
  calGainFast2500 Decimal @map("CalGainFast2500") @db.Decimal(12, 6)
  calGainSlow34   Decimal @map("CalGainSlow34") @db.Decimal(12, 6)
  calGainMed34    Decimal @map("CalGainMed34") @db.Decimal(12, 6)
  calGainFast34   Decimal @map("CalGainFast34") @db.Decimal(12, 6)
  calOffset       Decimal @map("CalOffset") @db.Decimal(12, 6)

  logger MwqLoggerSystemInfo @relation(fields: [loggerId], references: [id])

  @@map("mwq_logger_calibration_infos")
}

// Entity 26: StationHealthMetaData [BigInt PK]
model MwqStationHealthMetaData {
  id              BigInt   @id @default(autoincrement()) @map("HealthID")
  loggerId        Int      @map("LoggerID")
  timestamp       DateTime @map("Timestamp") @db.Timestamptz(6)
  battery         Decimal  @map("Battery") @db.Decimal(5, 2)
  panelTemp       Decimal  @map("PanelTemp") @db.Decimal(5, 2)
  memoryFree      Int      @map("MemoryFree")
  cpuDriveFree    Int      @map("CPUDriveFree")
  dataStorageSize Int      @map("DataStorageSize")
  dataStorageFree Int      @map("DataStorageFree")
  processTime     Int      @map("ProcessTime")
  maxProcessTime  Int      @map("MaxProcessTime")
  measureTime     Int      @map("MeasureTime")
  fullMemReset    Boolean  @map("FullMemReset")

  logger MwqLoggerSystemInfo @relation(fields: [loggerId], references: [id])

  @@map("mwq_station_health_metadata")
}
