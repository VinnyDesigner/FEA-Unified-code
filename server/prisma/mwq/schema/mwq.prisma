// mwq.prisma — Marine Water Quality module (26 entities)
// All models prefixed Mwq* to avoid collision with AQMS namespace.

// Entity 1: BuoysData
model MwqBuoy {
  id        Int     @id @default(autoincrement()) @map("BuoyID")
  buoyName  String  @map("BuoyName") @db.VarChar(120)
  latitude  Decimal @map("Latitude") @db.Decimal(9, 6)
  longitude Decimal @map("Longitude") @db.Decimal(9, 6)
  remarks   String? @map("Remarks")

  buoySensors         MwqBuoySensor[]
  sondeObservations   MwqSondeObservation[]
  weatherObservations MwqWeatherObservation[]
  gpsObservations     MwqGpsObservation[]
  batteryObservations MwqBatteryObservation[]
  doorObservations    MwqDoorObservation[]
  dataCaptureRates    MwqDataCaptureRate[]
  dataCaptureHourly   MwqDataCaptureRateHourly[]
  dataCaptureMonthly  MwqDataCaptureRateMonthly[]
  hourlySummaries     MwqHourlySummary[]
  dailySummaries      MwqDailySummary[]
  monthlySummaries    MwqMonthlySummary[]
  stationAlerts       MwqStationAlert[]
  stationMedia        MwqStationMedia[]
  windRoseSummaries   MwqWindRoseSummary[]
  loggerSystemInfos   MwqLoggerSystemInfo[]

  @@map("mwq_buoys")
}

// Entity 2: SensorDetails (MWQ sensor catalog)
model MwqSensorCatalog {
  id           Int     @id @default(autoincrement()) @map("SensorID")
  sensorName   String  @map("SensorName") @db.VarChar(120)
  sensorType   String  @map("SensorType") @db.VarChar(60)
  model        String  @map("Model") @db.VarChar(120)
  manufacturer String  @map("Manufacturer") @db.VarChar(120)
  remarks      String? @map("Remarks")

  buoySensors         MwqBuoySensor[]
  sondeObservations   MwqSondeObservation[]
  weatherObservations MwqWeatherObservation[]
  gpsObservations     MwqGpsObservation[]
  batteryObservations MwqBatteryObservation[]
  doorObservations    MwqDoorObservation[]
  dataCaptureRates    MwqDataCaptureRate[]
  dataCaptureHourly   MwqDataCaptureRateHourly[]
  dataCaptureMonthly  MwqDataCaptureRateMonthly[]
  hourlySummaries     MwqHourlySummary[]
  dailySummaries      MwqDailySummary[]
  monthlySummaries    MwqMonthlySummary[]

  @@map("mwq_sensor_catalog")
}

// Entity 3: BuoySensorDetails (junction)
model MwqBuoySensor {
  id            Int     @id @default(autoincrement()) @map("BuoySensorID")
  buoyId        Int     @map("BuoyID")
  sensorId      Int     @map("SensorID")
  dataFrequency String  @map("DataFrequency") @db.VarChar(40)
  status        String  @map("Status") @db.VarChar(20)
  remarks       String? @map("Remarks")

  buoy   MwqBuoy          @relation(fields: [buoyId], references: [id])
  sensor MwqSensorCatalog @relation(fields: [sensorId], references: [id])

  sondeObservations   MwqSondeObservation[]
  weatherObservations MwqWeatherObservation[]
  gpsObservations     MwqGpsObservation[]
  batteryObservations MwqBatteryObservation[]
  doorObservations    MwqDoorObservation[]
  dataCaptureRates    MwqDataCaptureRate[]
  dataCaptureHourly   MwqDataCaptureRateHourly[]
  dataCaptureMonthly  MwqDataCaptureRateMonthly[]
  hourlySummaries     MwqHourlySummary[]
  dailySummaries      MwqDailySummary[]
  monthlySummaries    MwqMonthlySummary[]

  @@map("mwq_buoy_sensors")
}

// Entity 4: ParameterUnit
model MwqParameterUnit {
  id       Int    @id @default(autoincrement()) @map("UnitID")
  unitName String @map("UnitName") @db.VarChar(60)
  unit     String @map("Unit") @db.VarChar(40)

  parameters MwqParameterMaster[]

  @@map("mwq_parameter_units")
}

// Entity 5: MonitoringParameterMaster
model MwqParameterMaster {
  id            Int     @id @default(autoincrement()) @map("ParameterID")
  sensorType    String  @map("SensorType") @db.VarChar(60)
  parameterName String  @map("ParameterName") @db.VarChar(120)
  unitId        Int     @map("UnitID")
  description   String? @map("Description")

  unit MwqParameterUnit @relation(fields: [unitId], references: [id])

  thresholds          MwqParameterThreshold[]
  sondeObservations   MwqSondeObservation[]
  weatherObservations MwqWeatherObservation[]
  gpsObservations     MwqGpsObservation[]
  batteryObservations MwqBatteryObservation[]
  doorObservations    MwqDoorObservation[]
  dataCaptureRates    MwqDataCaptureRate[]
  dataCaptureHourly   MwqDataCaptureRateHourly[]
  dataCaptureMonthly  MwqDataCaptureRateMonthly[]
  hourlySummaries     MwqHourlySummary[]
  dailySummaries      MwqDailySummary[]
  monthlySummaries    MwqMonthlySummary[]
  alertMasters        MwqAlertMaster[]

  @@map("mwq_parameter_masters")
}

// Entity 6: ParameterThreshold
model MwqParameterThreshold {
  id          Int     @id @default(autoincrement()) @map("ThresholdID")
  parameterId Int     @map("ParameterID")
  minValue    Decimal @map("MinValue") @db.Decimal(12, 4)
  maxValue    Decimal @map("MaxValue") @db.Decimal(12, 4)
  remarks     String? @map("Remarks")

  parameter    MwqParameterMaster @relation(fields: [parameterId], references: [id])
  alertMasters MwqAlertMaster[]

  @@map("mwq_parameter_thresholds")
}

// Entity 7: SondeObservation [partition weekly] [BigInt PK]
model MwqSondeObservation {
  id              BigInt   @id @default(autoincrement()) @map("ObservationID")
  buoySensorId    Int      @map("BuoySensorID")
  observationTime DateTime @map("ObservationTime") @db.Timestamptz(6)
  parameterId     Int      @map("ParameterID")
  value           Decimal  @map("Value") @db.Decimal(12, 4)
  buoyId          Int      @map("BuoyID")
  sensorId        Int      @map("SensorID")

  buoySensor MwqBuoySensor      @relation(fields: [buoySensorId], references: [id])
  parameter  MwqParameterMaster @relation(fields: [parameterId], references: [id])
  buoy       MwqBuoy            @relation(fields: [buoyId], references: [id])
  sensor     MwqSensorCatalog   @relation(fields: [sensorId], references: [id])

  @@index([buoyId, parameterId, observationTime(sort: Desc)])
  @@map("mwq_sonde_observations")
}

