// Entity 12: DataCaptureRate (daily)
model MwqDataCaptureRate {
  id                         Int      @id @default(autoincrement()) @map("CaptureRateID")
  buoySensorId               Int      @map("BuoySensorID")
  parameterId                Int      @map("ParameterID")
  date                       DateTime @map("Date") @db.Date
  expectedRecords            Int      @map("ExpectedRecords")
  receivedRecords            Int      @map("ReceivedRecords")
  validRecords               Int      @map("ValidRecords")
  captureRatePercentage      Decimal  @map("CaptureRatePercentage") @db.Decimal(5, 2)
  validCaptureRatePercentage Decimal  @map("ValidCaptureRatePercentage") @db.Decimal(5, 2)
  buoyId                     Int      @map("BuoyID")
  sensorId                   Int      @map("SensorID")

  buoySensor MwqBuoySensor      @relation(fields: [buoySensorId], references: [id])
  parameter  MwqParameterMaster @relation(fields: [parameterId], references: [id])
  buoy       MwqBuoy            @relation(fields: [buoyId], references: [id])
  sensor     MwqSensorCatalog   @relation(fields: [sensorId], references: [id])

  @@unique([buoyId, sensorId, parameterId, date])
  @@map("mwq_data_capture_rates")
}

