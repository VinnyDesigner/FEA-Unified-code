// Entity 18: AlertMaster
model MwqAlertMaster {
  id            Int       @id @default(autoincrement()) @map("AlertMasterID")
  alertCode     String    @unique @map("AlertCode") @db.VarChar(40)
  alertType     String    @map("AlertType") @db.VarChar(60)
  alertMessage  String    @map("AlertMessage")
  alertLevel    String    @map("AlertLevel") @db.VarChar(20)
  alertTime     DateTime? @map("AlertTime") @db.Timestamptz(6)
  alertCategory String    @map("AlertCategory") @db.VarChar(60)
  thresholdId   Int?      @map("ThresholdID")
  parameterId   Int?      @map("ParameterID")

  threshold     MwqParameterThreshold? @relation(fields: [thresholdId], references: [id])
  parameter     MwqParameterMaster?    @relation(fields: [parameterId], references: [id])
  stationAlerts MwqStationAlert[]

  @@map("mwq_alert_masters")
}

// Entity 19: StationAlert [BigInt PK]
model MwqStationAlert {
  id            BigInt    @id @default(autoincrement()) @map("AlertID")
  buoyId        Int       @map("BuoyID")
  sensorId      Int       @map("SensorID")
  alertMasterId Int       @map("AlertMasterID")
  alertTime     DateTime  @map("AlertTime") @db.Timestamptz(6)
  alertStatus   String    @map("AlertStatus") @db.VarChar(20)
  resolvedTime  DateTime? @map("ResolvedTime") @db.Timestamptz(6)
  alertValue    Decimal?  @map("AlertValue") @db.Decimal(12, 4)
  remarks       String?   @map("Remarks")

  buoy        MwqBuoy        @relation(fields: [buoyId], references: [id])
  alertMaster MwqAlertMaster @relation(fields: [alertMasterId], references: [id])

  @@index([buoyId, alertTime(sort: Desc)])
  @@map("mwq_station_alerts")
}

// Entity 20: StationMedia
model MwqStationMedia {
  id        Int     @id @default(autoincrement()) @map("MediaID")
  buoyId    Int     @map("BuoyID")
  mediaType String  @map("MediaType") @db.VarChar(40)
  fileName  String  @map("FileName") @db.VarChar(255)
  filePath  String  @map("FilePath") @db.VarChar(512)
  remarks   String? @map("Remarks")

  buoy MwqBuoy @relation(fields: [buoyId], references: [id])

  @@map("mwq_station_media")
}

// Entity 21: WindRoseSummary
model MwqWindRoseSummary {
