generator client {
  provider        = "prisma-client-js"
  output          = "../../../node_modules/.prisma/client-mwq"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_MWQ")
}

enum Module {
  AQMS
  MWQ
}

enum ReportFormat {
  XLSX
  DOCX
  PDF
}

enum AlarmSeverity {
  INFO
  WARN
  CRITICAL
}

enum AlarmCode {
  COMM_LOST
  DOOR_OPEN
  GPS_LOST
  BATTERY_LOW
  SENSOR_FAULT
  POWER_FAULT
  THRESHOLD_EXCEEDED
  OFFLINE
}

enum ReportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}
