# FEA backend env config
# Copy to .env and fill in real values. Never commit .env.

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
INTERNAL_PORT=5001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL_MWQ=postgresql://postgres:postgres@localhost:5432/fea_mwq_dev?schema=public
DATABASE_URL_AQMS=postgresql://postgres:postgres@localhost:5432/fea_aqms_dev?schema=public
# Higher-level identity/auth/RBAC DB (single source of truth for users + access)
DATABASE_URL_HIGHER_LEVEL=postgresql://postgres:postgres@localhost:5432/fea_higher_level_dev?schema=public

# ── Auth (Phase 2) ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# JWT_REFRESH_SECRET MUST be a DIFFERENT value than JWT_SECRET. Both ≥ 32 chars.
JWT_SECRET=change-me-min-32-chars-required-use-randomBytes
JWT_REFRESH_SECRET=change-me-DIFFERENT-from-JWT_SECRET-min-32-chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_COST=12

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Seed ─────────────────────────────────────────────────────────────────────
SEED_SENSOR_ROWS=50000     # dev default; set 1000000 for perf gate
SEED_DAYS=30
SEED_BUOYS=4
SEED_STATIONS=3

# ── OTP ──────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_LENGTH=4
OTP_MAX_ATTEMPTS=5

# ── SMTP (optional in dev — uses jsonTransport fallback) ─────────────────────
SMTP_FROM="FEA Unified <no-reply@fea.local>"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Cloudflare R2 storage (optional in dev — uses local disk) ────────────────
# R2_ENDPOINT=
# R2_BUCKET=fea-reports
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_PRESIGN_TTL_SECONDS=900

# ── Exports ──────────────────────────────────────────────────────────────────
MAX_CONCURRENT_EXPORTS=2
